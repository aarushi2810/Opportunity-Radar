# ── API Keys ──────────────────────────────────────────────────
GEMINI_API_KEY=          # Optional — enables LLM-powered classification

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Application ───────────────────────────────────────────────
DEMO_MODE=true           # Set to "false" for production
FILING_POLL_INTERVAL=900 # Seconds between filing polls (default: 15 min)

# ── Thresholds ────────────────────────────────────────────────
SIGNAL_THRESHOLD=0.65
NOVELTY_THRESHOLD=0.5
HUMAN_REVIEW_THRESHOLD=0.7
