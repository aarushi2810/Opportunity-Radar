# ══════════════════════════════════════════════════════════════════════════════
# Opportunity Radar — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required for AI features ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── JWT authentication ────────────────────────────────────────────────────────
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_in_production

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for aiosqlite local dev (no setup required).
# Set on Render using the Postgres add-on connection string.
# Render provides a postgres:// URL — the app converts it to asyncpg automatically.
DATABASE_URL=

# ── Cache ─────────────────────────────────────────────────────────────────────
# Leave blank for fakeredis local dev.
# Set on Render using the Redis add-on URL.
REDIS_URL=

# ── Market Data (optional — falls back to static JSON) ────────────────────────
# Free tier: 25 requests/day.  Get key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Pipeline Tuning ───────────────────────────────────────────────────────────
# DEMO_MODE=true: faster polling (10s), static data fallbacks.
# DEMO_MODE=false: 15-min polling, live NSE/Alpha Vantage data.
DEMO_MODE=true

FILING_POLL_INTERVAL=900       # seconds between NSE/BSE polls (production)
MARKET_DATA_CACHE_TTL=60       # seconds Redis caches live prices
SIGNAL_THRESHOLD=0.65          # minimum importance_score to route to enricher
HUMAN_REVIEW_THRESHOLD=0.70    # confidence below this flags for human review
